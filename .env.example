# Firebase - najdete v Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=shiftflow-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shiftflow-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=shiftflow-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef

# Firebase Cloud Messaging VAPID key
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=BKxxxxxxx...

# Google Apps Script Web App URL (Deploy → New deployment → Web app)
VITE_GAS_URL=https://script.google.com/macros/s/XXXX/exec
